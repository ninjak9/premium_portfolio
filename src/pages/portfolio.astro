---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | Portfolio Website">
	<section class="mb-16">
		<h1 class="text-h1 font-semibold mb-4">Curated Works.</h1>
		<p class="text-secondary max-w-[650px]">A selection of projects where precision meets performance. Each project represents a unique challenge in digital craft.</p>
	</section>

	<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
		{[1, 2, 3, 4].map((i) => (
			<div class="group cursor-pointer">
				<div class="aspect-video rounded-2xl bg-surface-tint/5 border border-white/10 overflow-hidden mb-6 relative">
					<div class="absolute inset-0 bg-accent/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
						<span class="bg-primary text-neutral px-6 py-2 rounded-full font-medium translate-y-4 group-hover:translate-y-0 transition-transform">View Project</span>
					</div>
					<!-- Placeholder for project image -->
					<div class="w-full h-full flex items-center justify-center text-white/5 text-8xl font-bold italic">0{i}</div>
				</div>
				<div class="flex justify-between items-end px-2">
					<div>
						<h3 class="text-h2 font-medium mb-1">Project Name {i}</h3>
						<p class="text-secondary text-sm">Visual Design • Motion • Development</p>
					</div>
					<div class="text-accent opacity-0 group-hover:opacity-100 transition-opacity">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
					</div>
				</div>
			</div>
		))}
	</div>
</Layout>

<style>
	.text-h1 {
		font-size: 48px;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}
	.text-h2 {
		font-size: 32px;
		line-height: 1.3;
		letter-spacing: -0.01em;
	}
</style>
