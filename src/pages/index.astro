---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Portfolio Website">
	<section class="mb-24">
		<h1 class="text-display font-semibold mb-6">Atmospheric Precision.</h1>
		<p class="text-body-lg text-secondary max-w-[650px]">
			A digital space where quiet authority meets meticulous craft. Explore a collection of works defined by minimalism and high-execution glassmorphism.
		</p>
	</section>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-5">
		<!-- Main Hero Bento Item -->
		<div class="md:col-span-2 aspect-[16/9] rounded-2xl bg-surface-tint/5 border border-white/10 backdrop-blur-xl p-8 flex flex-col justify-end overflow-hidden relative group">
			<div class="absolute inset-0 bg-gradient-to-t from-background to-transparent opacity-60"></div>
			<div class="relative z-10">
				<span class="text-label-sm uppercase tracking-widest text-accent mb-2 block">Featured Work</span>
				<h2 class="text-h1 font-semibold mb-4">Ethereal Noir System</h2>
				<p class="text-secondary mb-6 max-w-md">Finalizing the macOS utility with a high-fidelity "Absolute Shield" architecture.</p>
				<a href="/portfolio" class="inline-flex items-center gap-2 bg-primary text-neutral px-6 py-3 rounded-full font-medium hover:bg-primary/90 transition-all active:scale-95">
					View Case Study
				</a>
			</div>
		</div>

		<!-- Side Bento Item -->
		<div class="rounded-2xl bg-surface-tint/5 border border-white/10 backdrop-blur-xl p-8 flex flex-col justify-between overflow-hidden relative group">
			<div>
				<h3 class="text-h2 font-medium mb-2">Lab Sessions</h3>
				<p class="text-secondary text-sm">Experimental interactions and micro-animations.</p>
			</div>
			<a href="/side-projects" class="text-accent hover:underline flex items-center gap-2">
				Explore Lab →
			</a>
		</div>

		<!-- Smaller Bento Items -->
		<div class="rounded-2xl bg-surface-tint/5 border border-white/10 backdrop-blur-xl p-8 aspect-square flex flex-col justify-center items-center text-center">
			<div class="text-4xl font-bold mb-2">12+</div>
			<p class="text-secondary text-sm">Projects Completed</p>
		</div>

		<div class="rounded-2xl bg-surface-tint/5 border border-white/10 backdrop-blur-xl p-8 aspect-square flex flex-col justify-center items-center text-center">
			<div class="text-4xl font-bold mb-2">6</div>
			<p class="text-secondary text-sm">Design Awards</p>
		</div>

		<div class="rounded-2xl bg-surface-tint/5 border border-white/10 backdrop-blur-xl p-8 aspect-square flex flex-col justify-center items-center text-center">
			<div class="text-4xl font-bold mb-2">2026</div>
			<p class="text-secondary text-sm">Current Era</p>
		</div>
	</div>
</Layout>

<style>
	.text-display {
		font-size: 80px;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}
	.text-h1 {
		font-size: 48px;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}
	.text-h2 {
		font-size: 32px;
		line-height: 1.3;
		letter-spacing: -0.01em;
	}
	.text-body-lg {
		font-size: 20px;
		line-height: 1.6;
	}
	.text-label-sm {
		font-size: 12px;
		letter-spacing: 0.05em;
	}
</style>
