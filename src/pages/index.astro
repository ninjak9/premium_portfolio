---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Elias Voss Portfolio">
	<div class="space-y-24">
		<!-- Hero Section: Bento Grid -->
		<section class="grid grid-cols-1 md:grid-cols-12 gap-card-gap">
			<!-- Artistic Portrait Card -->
			<div class="md:col-span-8 h-[640px] rounded-[2.5rem] overflow-hidden glass glass-hover relative group">
				<div class="nebula-glow" style="--glow-color: rgba(79, 70, 229, 0.4);"></div>
				<img 
					class="absolute inset-0 w-full h-full object-cover grayscale brightness-[0.6] transition-transform duration-1000 group-hover:scale-110" 
					src="/hero.png" 
					alt="Elias Voss - Studio Portrait"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
				<div class="absolute bottom-12 left-12">
					<span class="text-label-sm text-white/50 mb-4 block">LONDON / BERLIN</span>
					<h1 class="text-display text-white italic">ELIAS VOSS.</h1>
				</div>
			</div>

			<!-- Brief About Card -->
			<div class="md:col-span-4 flex flex-col gap-card-gap">
				<div class="flex-1 glass glass-hover rounded-[2.5rem] p-12 flex flex-col justify-end overflow-hidden">
					<div class="nebula-glow" style="--glow-color: rgba(139, 92, 246, 0.25);"></div>
					<p class="text-h2 text-white leading-tight mb-8">Crafting at the intersection of logic & art.</p>
					<p class="text-body-md text-white/50">Multidisciplinary designer specializing in high-end identity systems and digital environments for the avant-garde.</p>
				</div>
				<div class="h-40 glass glass-hover rounded-[2.5rem] p-10 flex items-center justify-between group cursor-pointer transition-all overflow-hidden">
					<div class="nebula-glow" style="--glow-color: rgba(20, 184, 166, 0.15);"></div>
					<div>
						<span class="text-label-sm text-white/30 block mb-1">AVAILABILITY</span>
						<span class="text-white font-bold tracking-tight text-lg">OPEN TO PROJECTS</span>
					</div>
					<div class="w-14 h-14 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all duration-500">
						<span class="material-symbols-outlined font-light">north_east</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Work Experience Timeline -->
		<section class="grid grid-cols-1 md:grid-cols-12 gap-card-gap">
			<div class="md:col-span-4 glass glass-hover rounded-[2.5rem] p-12 overflow-hidden">
				<div class="nebula-glow" style="--glow-color: rgba(217, 70, 239, 0.12);"></div>
				<h2 class="text-h2 text-white mb-6 uppercase tracking-tighter">Timeline</h2>
				<p class="text-body-md text-white/50">A decade of refining aesthetics across continents and disciplines.</p>
			</div>
			<div class="md:col-span-8 glass glass-hover rounded-[2.5rem] p-12 overflow-hidden">
				<div class="nebula-glow" style="--glow-color: rgba(59, 130, 246, 0.1);"></div>
				<div class="space-y-16 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-white/5">
					<div class="relative pl-14">
						<div class="absolute left-0 top-3 w-6 h-6 rounded-full bg-white ring-8 ring-[#020204]"></div>
						<div class="flex flex-col md:flex-row md:justify-between md:items-baseline gap-4">
							<h3 class="text-[28px] font-bold text-white">Lead Identity Designer</h3>
							<span class="text-label-sm text-white/40 uppercase tracking-[0.2em]">2021 — NOW</span>
						</div>
						<p class="text-label-sm text-white/70 mb-4 mt-2">NOIRE AGENCY, PARIS</p>
						<p class="text-body-md text-white/40 max-w-2xl leading-relaxed">Defining visual languages for luxury fashion houses and boutique architectural firms with a focus on monochromatic precision.</p>
					</div>
					<div class="relative pl-14 opacity-50">
						<div class="absolute left-0 top-3 w-6 h-6 rounded-full bg-white/20 ring-8 ring-[#020204]"></div>
						<div class="flex flex-col md:flex-row md:justify-between md:items-baseline gap-4">
							<h3 class="text-[28px] font-bold text-white">Senior Product Designer</h3>
							<span class="text-label-sm text-white/40 uppercase tracking-[0.2em]">2018 — 2021</span>
						</div>
						<p class="text-label-sm text-white/70 mb-4 mt-2">AETHER TECH, TOKYO</p>
						<p class="text-body-md text-white/40 max-w-2xl leading-relaxed">Architecting minimalist interfaces for decentralized finance platforms and AI tooling for research laboratories.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Portfolio Unified Grid -->
		<section class="space-y-12">
			<div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8">
				<div>
					<span class="text-label-sm text-white/30 uppercase tracking-[0.3em] block mb-4">GALLERY</span>
					<h2 class="text-h1 text-white">Selected Works</h2>
				</div>
				<div class="flex gap-3">
					<span class="px-8 py-3 rounded-full bg-white text-black text-label-sm cursor-pointer transition-transform hover:scale-105">ALL</span>
					<span class="px-8 py-3 rounded-full glass glass-hover text-white/50 text-label-sm cursor-pointer hover:text-white hover:bg-white/10 transition-all">DIGITAL</span>
					<span class="px-8 py-3 rounded-full glass glass-hover text-white/50 text-label-sm cursor-pointer hover:text-white hover:bg-white/10 transition-all">PRINT</span>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-card-gap">
				<!-- Project 1 -->
				<div class="group relative aspect-[4/5] rounded-[2.5rem] overflow-hidden glass glass-hover cursor-pointer shadow-2xl">
					<div class="nebula-glow" style="--glow-color: rgba(59, 130, 246, 0.2);"></div>
					<img 
						class="w-full h-full object-cover grayscale brightness-90 transition-transform duration-1000 group-hover:scale-110" 
						src="/hero.png" 
						alt="Monolith Systems"
					/>
					<div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-12 backdrop-blur-sm">
						<span class="text-label-sm text-white/60 mb-2">IDENTITY / 2023</span>
						<h3 class="text-h2 text-white italic">Monolith Systems</h3>
					</div>
				</div>
				<!-- Project 2 -->
				<div class="group relative aspect-[4/5] rounded-[2.5rem] overflow-hidden glass glass-hover cursor-pointer shadow-2xl">
					<div class="nebula-glow" style="--glow-color: rgba(139, 92, 246, 0.2);"></div>
					<img 
						class="w-full h-full object-cover grayscale brightness-90 transition-transform duration-1000 group-hover:scale-110" 
						src="/lab.png" 
						alt="The Void Journal"
					/>
					<div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-12 backdrop-blur-sm">
						<span class="text-label-sm text-white/60 mb-2">EDITORIAL / 2024</span>
						<h3 class="text-h2 text-white italic">The Void Journal</h3>
					</div>
				</div>
			</div>
		</section>

		<!-- Side Quests -->
		<section class="space-y-12">
			<div class="flex flex-col gap-3">
				<span class="text-label-sm text-accent uppercase tracking-[0.3em]">LAB EXPERIMENTS</span>
				<h2 class="text-h1 text-white">Side Quests</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-card-gap">
				<!-- App 1 -->
				<div class="glass glass-hover rounded-[2rem] p-10 flex flex-col justify-between aspect-square group cursor-pointer transition-all hover:bg-accent/10 hover:-translate-y-2 overflow-hidden">
					<div class="nebula-glow" style="--glow-color: rgba(139, 92, 246, 0.25);"></div>
					<span class="material-symbols-outlined text-accent text-5xl font-extralight transition-transform group-hover:scale-110 duration-500">blur_on</span>
					<div>
						<h4 class="text-[24px] font-bold text-white mb-2">Haze</h4>
						<p class="text-label-sm text-white/40 leading-relaxed">Mood-based gradient generator for digital artists.</p>
					</div>
				</div>
				<!-- App 2 -->
				<div class="glass glass-hover rounded-[2rem] p-10 flex flex-col justify-between aspect-square group cursor-pointer transition-all hover:bg-accent/10 hover:-translate-y-2 overflow-hidden">
					<div class="nebula-glow" style="--glow-color: rgba(59, 130, 246, 0.25);"></div>
					<span class="material-symbols-outlined text-accent text-5xl font-extralight transition-transform group-hover:scale-110 duration-500">auto_awesome</span>
					<div>
						<h4 class="text-[24px] font-bold text-white mb-2">Lumina</h4>
						<p class="text-label-sm text-white/40 leading-relaxed">Real-time light study tool for photographers.</p>
					</div>
				</div>
				<!-- App 3 -->
				<div class="glass glass-hover rounded-[2rem] p-10 flex flex-col justify-between aspect-square group cursor-pointer transition-all hover:bg-accent/10 hover:-translate-y-2 overflow-hidden">
					<div class="nebula-glow" style="--glow-color: rgba(14, 165, 233, 0.25);"></div>
					<span class="material-symbols-outlined text-accent text-5xl font-extralight transition-transform group-hover:scale-110 duration-500">token</span>
					<div>
						<h4 class="text-[24px] font-bold text-white mb-2">Grid.io</h4>
						<p class="text-label-sm text-white/40 leading-relaxed">Recursive grid construction kit for web design.</p>
					</div>
				</div>
				<!-- App 4 -->
				<div class="glass glass-hover rounded-[2rem] p-10 flex flex-col justify-between aspect-square group cursor-pointer transition-all hover:bg-accent/10 hover:-translate-y-2 overflow-hidden">
					<div class="nebula-glow" style="--glow-color: rgba(217, 70, 239, 0.25);"></div>
					<span class="material-symbols-outlined text-accent text-5xl font-extralight transition-transform group-hover:scale-110 duration-500">waves</span>
					<div>
						<h4 class="text-[24px] font-bold text-white mb-2">VibeCheck</h4>
						<p class="text-label-sm text-white/40 leading-relaxed">Aesthetic harmony analyzer for brand palettes.</p>
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>
